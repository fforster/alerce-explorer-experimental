# Copy to `.env` and fill in. `.env` is git-ignored and never enters the image.
#   cp .env.example .env
#
# .env.example holds PLACEHOLDERS only — never put real secrets here.

# Public base URL the app uses to build absolute links in htmx fragments
# (injected into Jinja as API_URL). In production this MUST be the https
# domain, or fragments will build broken/insecure URLs.
API_URL=https://explorer-experiment.alerce.online

# --- Future app secrets go below (read via os.getenv in the app) ---
# In real production prefer pulling these from AWS Secrets Manager / SSM
# Parameter Store via the instance IAM role, rather than a plaintext .env.
# Examples (currently unused):
# DUST_PROXY_TOKEN=
# DATABASE_URL=
