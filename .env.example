# Copy to `.env` and fill in. `.env` is git-ignored and never enters the image.
#   cp .env.example .env
#
# .env.example holds PLACEHOLDERS only — never put real secrets here.

# Public base URL the app uses to build absolute links in htmx fragments
# (injected into Jinja as API_URL). In production this MUST be the https
# domain, or fragments will build broken/insecure URLs.
API_URL=https://explorer-experiment.alerce.online

# --- Session-replay analytics (services/analytics.py) ---
# Collection is OFF by default. Set to 1/true to start recording sessions.
# Logs are written to ./logs/analytics/ (git- and docker-ignored); in compose
# that path is a bind mount onto the host's ./logs dir.
ANALYTICS_ENABLED=0
# Secret salt for the per-visitor IP hash (raw IPs are never stored). Set to a
# long random string in production so the hashes can't be reversed via a
# lookup table of all IPs. Leave blank to use the non-secret built-in default.
ANALYTICS_IP_SALT=
# ANALYTICS_LOG_DIR overrides the log directory; leave unset to use the default
# ./logs/analytics next to the code.

# --- Future app secrets go below (read via os.getenv in the app) ---
# In real production prefer pulling these from AWS Secrets Manager / SSM
# Parameter Store via the instance IAM role, rather than a plaintext .env.
# Examples (currently unused):
# DUST_PROXY_TOKEN=
# DATABASE_URL=
