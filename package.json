{
  "private": true,
  "devDependencies": {
    "jsdom": "^25.0.0",
    "tailwindcss": "^3.4.17",
    "vitest": "^2.1.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/static/css/tailwind.css -o ./src/static/css/main.css --minify",
    "watch:css": "tailwindcss -i ./src/static/css/tailwind.css -o ./src/static/css/main.css --watch",
    "test:js": "vitest run",
    "test:js:watch": "vitest"
  }
}
