{#
  catsHTM crossmatch panel body — populated by /htmx/crossmatch into the
  #crossmatch-body div that lives inside a <details> in the detail
  container. We render only the body here; the chrome (title/expander)
  lives in the container so the user can collapse the panel without losing
  the loaded data.

  ctx shape: {available, ra, dec, radius, catalogs:[{name, fields:[{key, value, unit}]}],
              n_catalogs, error}.

  Each catsHTM catalog returns a single row (the closest match), so we
  render one per-catalog table with the columns coming straight from the
  payload — keys differ across catalogs, so a unified column set isn't
  meaningful. Future xmatch sources will appear as additional cards in the
  same list.
#}
{#
  Bulk CDS/NED crossmatch (services/xmatch.py), folded in above catsHTM. `xm`
  shape: {matches:[{cat_name,category,name,type,z,sep,fields:[{label,value,unit}],
  color,signals}], hints:{stellar,agn,host}, best_z, simbad_type, counts, overlay}.
  Matches are pre-ordered stellar → AGN → host (nearest first), since a tight-
  radius star/AGN counterpart is the strongest classifier. Served from the
  page-load prefetch cache, so this is usually instant.
#}
{% if xm and xm.matches %}
  <div class="tw-mb-4">
    <div class="tw-text-xs tw-font-semibold tw-text-accent tw-mb-2">
      Crossmatch &mdash; CDS / NED
    </div>
    {# Classification hint banner: what kind of object this likely is. #}
    {% if xm.hints and (xm.hints.stellar or xm.hints.agn or xm.hints.host) %}
      <div class="tw-mb-3 tw-flex tw-flex-col tw-gap-1 tw-text-[11px]">
        {% for cat, color in [("stellar", "#42a5f5"), ("agn", "#ef5350"), ("host", "#9ccc65")] %}
          {% if xm.hints[cat] %}
            <div class="tw-flex tw-items-center tw-gap-1.5">
              <span class="tw-inline-block tw-rounded-full" style="width:8px;height:8px;background:{{ color }}"></span>
              <span class="tw-text-text-primary">{{ xm.hints[cat] }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
    {# Single ordered column of matches (stars → AGN → host); colour-coded by
       category via a left border. Fields are catalog-specific (parallax / PM /
       variable type / class / z / morphology). #}
    <div class="tw-flex tw-flex-col tw-gap-1.5">
      {% for m in xm.matches %}
        <div class="tw-border-l-2 tw-pl-2 tw-py-0.5 tw-text-[11px]" style="border-color: {{ m.color }}">
          <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-wrap">
            <span class="tw-font-semibold tw-text-text-primary">{{ m.cat_name }}</span>
            <span class="tw-text-text-muted tw-uppercase tw-text-[9px]">{{ m.category }}</span>
            {% if m.sep is not none %}<span class="tw-text-text-muted mono">{{ "%.2f"|format(m.sep) }}&Prime;</span>{% endif %}
          </div>
          <div class="tw-text-text-secondary mono tw-flex tw-flex-wrap tw-gap-x-3 tw-gap-y-0.5">
            {% if m.name %}<span class="tw-text-text-primary tw-truncate tw-max-w-[16rem]">{{ m.name }}</span>{% endif %}
            {% for f in m.fields %}
              <span>{{ f.label }}&nbsp;{% if f.value is number %}{{ "%.4g"|format(f.value) }}{% else %}{{ f.value }}{% endif %}{% if f.unit %}&nbsp;{{ f.unit }}{% endif %}</span>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="tw-mt-3 tw-mb-1 tw-text-xs tw-font-semibold tw-text-accent">catsHTM</div>
  </div>
{% endif %}
{% if not ctx.available %}
  <div class="tw-text-text-muted tw-py-3">No coordinates available for crossmatch.</div>
{% elif ctx.error %}
  <div class="tw-text-red-400 tw-py-3">catsHTM error: {{ ctx.error }}</div>
{% elif not ctx.catalogs %}
  <div class="tw-text-text-muted tw-py-3">
    No crossmatch results within {{ "%g"|format(ctx.radius) }}&Prime;.
  </div>
{% else %}
  <div class="tw-text-text-muted tw-text-[11px] tw-mb-2">
    {{ ctx.n_catalogs }} catalog{{ "" if ctx.n_catalogs == 1 else "s" }} matched within
    {{ "%g"|format(ctx.radius) }}&Prime;
    (RA {{ "%.5f"|format(ctx.ra) }}, Dec {{ "%.5f"|format(ctx.dec) }}).
  </div>
  <div class="tw-flex tw-flex-col tw-gap-3">
    {% for cat in ctx.catalogs %}
      <div class="tw-border tw-border-border tw-rounded">
        <div class="tw-px-3 tw-py-1.5 tw-text-xs tw-font-semibold tw-text-accent tw-border-b tw-border-border">
          catsHTM &mdash; {{ cat.name }}
        </div>
        <div class="tw-overflow-auto">
          <table class="xmatch-table tw-w-full tw-text-[11px] mono">
            <thead>
              <tr class="tw-text-text-muted">
                {% for f in cat.fields %}
                  <th class="tw-text-left tw-px-2 tw-py-1 tw-font-semibold tw-uppercase tw-text-[10px] tw-whitespace-nowrap">
                    {{ f.key }}{% if f.unit %} <span class="tw-text-text-secondary tw-normal-case tw-font-normal">[{{ f.unit }}]</span>{% endif %}
                  </th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              <tr>
                {% for f in cat.fields %}
                  <td class="tw-px-2 tw-py-1 tw-text-text-primary tw-whitespace-nowrap">{{ f.value }}</td>
                {% endfor %}
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
