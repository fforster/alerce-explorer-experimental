{#
  catsHTM crossmatch panel body — populated by /htmx/crossmatch into the
  #crossmatch-body div that lives inside a <details> in the detail
  container. We render only the body here; the chrome (title/expander)
  lives in the container so the user can collapse the panel without losing
  the loaded data.

  ctx shape: {available, ra, dec, radius, catalogs:[{name, fields:[{key, value, unit}]}],
              n_catalogs, error}.

  Each catsHTM catalog returns a single row (the closest match), so we
  render one per-catalog table with the columns coming straight from the
  payload — keys differ across catalogs, so a unified column set isn't
  meaningful. Future xmatch sources will appear as additional cards in the
  same list.
#}
{#
  Bulk CDS/NED crossmatch (services/xmatch.py), folded in above catsHTM. `xm`
  shape: {by_catalog:{cat:[{name,ra,dec,z,z_err,photoz,type,sep}]}, best_z:
  {z,z_err,source,sep}, simbad_type, counts:{cat:n}, overlay:[…]}. Served from
  the page-load prefetch cache, so this is usually instant.
#}
{% if xm and xm.counts %}
  <div class="tw-mb-4">
    <div class="tw-text-xs tw-font-semibold tw-text-accent tw-mb-1.5">
      Redshift crossmatch &mdash; CDS / NED
    </div>
    {# Summary line: best spec-z, SIMBAD type, per-catalog match counts. #}
    <div class="tw-text-[11px] tw-text-text-secondary tw-mb-2 tw-flex tw-flex-col tw-gap-0.5">
      {% if xm.best_z %}
        <div>
          Best spec-<i>z</i>:
          <span class="tw-text-text-primary mono">{{ "%.5f"|format(xm.best_z.z) }}</span>{% if xm.best_z.z_err is not none %}<span class="mono"> &plusmn; {{ "%.5f"|format(xm.best_z.z_err) }}</span>{% endif %}
          from <span class="tw-text-text-primary">{{ xm.best_z.source }}</span>{% if xm.best_z.sep is not none %} ({{ "%.2f"|format(xm.best_z.sep) }}&Prime;){% endif %}
        </div>
      {% else %}
        <div>No spectroscopic redshift among the matched catalogs.</div>
      {% endif %}
      {% if xm.simbad_type %}<div>SIMBAD type: <span class="tw-text-text-primary">{{ xm.simbad_type }}</span></div>{% endif %}
      <div>
        Matched:
        {% for cat, n in xm.counts.items() %}<span class="tw-text-text-primary">{{ cat }}</span>&nbsp;{{ n }}{% if not loop.last %} &middot; {% endif %}{% endfor %}
      </div>
    </div>
    {# One card per CDS/NED catalog with matches. #}
    <div class="tw-flex tw-flex-col tw-gap-3">
      {% for cat, rows in xm.by_catalog.items() %}
        <div class="tw-border tw-border-border tw-rounded">
          <div class="tw-px-3 tw-py-1.5 tw-text-xs tw-font-semibold tw-text-accent tw-border-b tw-border-border">
            {{ cat }}
          </div>
          <div class="tw-overflow-auto">
            <table class="xmatch-table tw-w-full tw-text-[11px] mono">
              <thead>
                <tr class="tw-text-text-muted">
                  {% for h in ["name", "ra", "dec", "z", "z_err", "type", "sep [″]"] %}
                    <th class="tw-text-left tw-px-2 tw-py-1 tw-font-semibold tw-uppercase tw-text-[10px] tw-whitespace-nowrap">{{ h }}</th>
                  {% endfor %}
                </tr>
              </thead>
              <tbody>
                {% for r in rows %}
                  <tr>
                    <td class="tw-px-2 tw-py-1 tw-text-text-primary tw-whitespace-nowrap">{{ r.name if r.name is not none else "&mdash;"|safe }}</td>
                    <td class="tw-px-2 tw-py-1 tw-whitespace-nowrap">{% if r.ra is not none %}{{ "%.5f"|format(r.ra) }}{% else %}&mdash;{% endif %}</td>
                    <td class="tw-px-2 tw-py-1 tw-whitespace-nowrap">{% if r.dec is not none %}{{ "%.5f"|format(r.dec) }}{% else %}&mdash;{% endif %}</td>
                    <td class="tw-px-2 tw-py-1 tw-whitespace-nowrap">{% if r.z is not none %}{{ "%.5f"|format(r.z) }}{% else %}&mdash;{% endif %}</td>
                    <td class="tw-px-2 tw-py-1 tw-whitespace-nowrap">{% if r.z_err is not none %}{{ "%.5f"|format(r.z_err) }}{% else %}&mdash;{% endif %}</td>
                    <td class="tw-px-2 tw-py-1 tw-text-text-primary tw-whitespace-nowrap">{{ r.type if r.type else "&mdash;"|safe }}</td>
                    <td class="tw-px-2 tw-py-1 tw-whitespace-nowrap">{% if r.sep is not none %}{{ "%.2f"|format(r.sep) }}{% else %}&mdash;{% endif %}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="tw-mt-3 tw-mb-1 tw-text-xs tw-font-semibold tw-text-accent">catsHTM</div>
  </div>
{% endif %}
{% if not ctx.available %}
  <div class="tw-text-text-muted tw-py-3">No coordinates available for crossmatch.</div>
{% elif ctx.error %}
  <div class="tw-text-red-400 tw-py-3">catsHTM error: {{ ctx.error }}</div>
{% elif not ctx.catalogs %}
  <div class="tw-text-text-muted tw-py-3">
    No crossmatch results within {{ "%g"|format(ctx.radius) }}&Prime;.
  </div>
{% else %}
  <div class="tw-text-text-muted tw-text-[11px] tw-mb-2">
    {{ ctx.n_catalogs }} catalog{{ "" if ctx.n_catalogs == 1 else "s" }} matched within
    {{ "%g"|format(ctx.radius) }}&Prime;
    (RA {{ "%.5f"|format(ctx.ra) }}, Dec {{ "%.5f"|format(ctx.dec) }}).
  </div>
  <div class="tw-flex tw-flex-col tw-gap-3">
    {% for cat in ctx.catalogs %}
      <div class="tw-border tw-border-border tw-rounded">
        <div class="tw-px-3 tw-py-1.5 tw-text-xs tw-font-semibold tw-text-accent tw-border-b tw-border-border">
          catsHTM &mdash; {{ cat.name }}
        </div>
        <div class="tw-overflow-auto">
          <table class="xmatch-table tw-w-full tw-text-[11px] mono">
            <thead>
              <tr class="tw-text-text-muted">
                {% for f in cat.fields %}
                  <th class="tw-text-left tw-px-2 tw-py-1 tw-font-semibold tw-uppercase tw-text-[10px] tw-whitespace-nowrap">
                    {{ f.key }}{% if f.unit %} <span class="tw-text-text-secondary tw-normal-case tw-font-normal">[{{ f.unit }}]</span>{% endif %}
                  </th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              <tr>
                {% for f in cat.fields %}
                  <td class="tw-px-2 tw-py-1 tw-text-text-primary tw-whitespace-nowrap">{{ f.value }}</td>
                {% endfor %}
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
