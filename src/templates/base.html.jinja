<!DOCTYPE html>
<html lang="en" class="tw-h-full">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<meta name="htmx-config" content='{"selfRequestsOnly": false}'/>
<title>{% block title %}ALeRCE Explorer (tutorial){% endblock %}</title>

{# Browser-tab favicon — same SVG used as the in-app header logo so the
   tab is recognisable at a glance. SVG scales cleanly to whatever icon
   size the browser asks for; the `image/svg+xml` type hint lets older
   browsers fall back gracefully if they don't support SVG favicons. #}
<link rel="icon" type="image/svg+xml" href="/static/img/alerce-logo.svg"/>
<link rel="apple-touch-icon" href="/static/img/alerce-logo.svg"/>

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

{# `?v=` cache-buster (latest static mtime) so edited JS/CSS is refetched
   instead of served from the browser's disk cache. See _asset_version. #}
{%- set v = asset_v() %}
<link rel="stylesheet" href="/static/css/main.css?v={{ v }}"/>

<script>window.API_URL = "{{ API_URL }}";</script>
<script src="/static/htmx/htmx.min.js"></script>
<script src="https://unpkg.com/htmx-ext-response-targets@2.0.2" crossorigin="anonymous"></script>
<script src="/static/chart-js/chart.umd.js"></script>
<script src="/static/chart-js/hammer.min.js"></script>
<script src="/static/chart-js/chartjs-plugin-zoom.min.js"></script>
<script src="/static/js/helpers.js?v={{ v }}" defer></script>
<script src="/static/js/panel_help.js?v={{ v }}" defer></script>
<script src="/static/js/coords.js?v={{ v }}" defer></script>
<script src="/static/js/object_nav.js?v={{ v }}" defer></script>
<script src="/static/js/selection.js?v={{ v }}" defer></script>
<script src="/static/js/cosmology.js?v={{ v }}" defer></script>
<script src="/static/js/dust.js?v={{ v }}" defer></script>
<script src="/static/js/lightcurve.js?v={{ v }}" defer></script>
<script src="/static/js/periodogram.js?v={{ v }}" defer></script>
<script src="/static/js/airmass.js?v={{ v }}" defer></script>
<script src="/static/js/stamps.js?v={{ v }}" defer></script>
<script src="/static/js/radar.js?v={{ v }}" defer></script>
<script src="/static/js/coord_residuals.js?v={{ v }}" defer></script>
<script src="/static/js/color_evolution.js?v={{ v }}" defer></script>
<script src="/static/js/specz.js?v={{ v }}" defer></script>
<script src="/static/js/aladin.js?v={{ v }}" defer></script>
{# Session-replay analytics — only shipped when the operator opts in via
   ANALYTICS_ENABLED, so "disabled" means these scripts aren't on the page.
   Served under neutral names (recorder.min.js / ux_recorder.js, not "rrweb" /
   "analytics") so Brave/uBlock tracker filter lists don't block them. #}
{% if analytics_enabled() %}
<script src="/static/vendor/recorder/recorder.min.js" defer></script>
<script src="/static/js/ux_recorder.js?v={{ v }}" defer></script>
{% endif %}
</head>
<body class="tw-h-full tw-bg-bg-primary tw-text-text-primary">
{% block body %}{% endblock %}
</body>
</html>
