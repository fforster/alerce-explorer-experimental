{# `data-nav` exposes the current page's OIDs + pagination state so the detail
   view's prev/next arrow buttons (and keyboard arrows) can move through the
   result set — and hop to the next/prev page when they run out of siblings.
   Rendered on every list_objects swap so it stays in sync with the filters. #}
{#
  `filter_qs` carries the current filter state into the row-click URLs so the
  detail view can echo it back into HX-Push-Url — preserving the search
  context across a drill-in/back round trip. Mirrors the emit rules of
  `_share_url` in routes/htmx.py (empty/default values are dropped).
#}
{%- set filter_qs %}
  {%- if classifier %}&classifier={{ classifier|urlencode }}{% endif %}
  {%- if classifier_version %}&classifier_version={{ classifier_version|urlencode }}{% endif %}
  {%- if class_name %}&class_name={{ class_name|urlencode }}{% endif %}
  {%- if probability and probability > 0 %}&probability={{ probability }}{% endif %}
  {%- if n_det_min is not none %}&n_det_min={{ n_det_min }}{% endif %}
  {%- if n_det_max is not none %}&n_det_max={{ n_det_max }}{% endif %}
  {%- if firstmjd_min is not none %}&firstmjd_min={{ firstmjd_min }}{% endif %}
  {%- if firstmjd_max is not none %}&firstmjd_max={{ firstmjd_max }}{% endif %}
  {%- if lastmjd_min is not none %}&lastmjd_min={{ lastmjd_min }}{% endif %}
  {%- if lastmjd_max is not none %}&lastmjd_max={{ lastmjd_max }}{% endif %}
  {%- if ra is not none and dec is not none %}&ra={{ ra }}&dec={{ dec }}{% if radius is not none %}&radius={{ radius }}{% endif %}{% endif %}
  {%- if oids %}&oids={{ oids|urlencode }}{% endif %}
  {%- if page and page > 1 %}&page={{ page }}{% endif %}
{%- endset %}
<style>
  /*
    Below Tailwind's lg breakpoint (1024 px), drop the lower-priority
    columns from the results table so the remaining columns (OID,
    Class, Prob) fit comfortably on phone widths instead of forcing a
    horizontal scroll. Marked with `.col-mobile-hide` on both <th>
    and <td>; toggled via a CSS class instead of `lg:` Tailwind
    variants so a stale Tailwind build doesn't drop the rule.
  */
  @media (max-width: 1023px) {
    #objects_table .col-mobile-hide { display: none; }
  }
  /*
    "Back to results" highlights the row of the object you were just viewing
    (helpers.js adds .row-return-highlight after restoring the listing): an
    initial pulse to draw the eye, settling to a persistent accent bar +
    faint tint so it stays findable. !important keeps the tint from being
    overridden by the row's hover background.
  */
  @keyframes rowReturnPulse {
    0%   { background-color: rgba(88, 166, 255, 0.40); }
    100% { background-color: rgba(88, 166, 255, 0.12); }
  }
  #objects_table tr.row-return-highlight {
    background-color: rgba(88, 166, 255, 0.12) !important;
    box-shadow: inset 3px 0 0 0 #1976d2;
    animation: rowReturnPulse 1.2s ease-out;
  }
</style>
<div
  id="objects_table"
  class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-relative"
  data-nav='{{ {
    "oids": objects_list["items"] | map(attribute="oid") | list,
    "current_page": objects_list["current_page"],
    "has_prev": objects_list["has_prev"],
    "has_next": objects_list["has_next"],
    "prev": objects_list["prev"] if objects_list["has_prev"] else None,
    "next": objects_list["next"] if objects_list["has_next"] else None,
    "survey": survey|default(none),
    "classifier": classifier|default(none),
    "total_pages": objects_list["total_pages"] if objects_list.get("total_pages") else None,
  } | tojson_compact }}'
>

  {#
    Bulk crossmatch prefetch: warm the CDS/NED cache for this page's objects
    (or the WHOLE OID-list set when known — `all_positions`) so opening any
    detail view renders its crossmatch + spec-z overlay instantly. Fires once
    per render via a tiny helper; off the critical path, never blocks the table.
    Coords are the meanra/meandec already shaped per row.
  #}
  <div
    id="xmatch-prefetch"
    class="tw-hidden"
    data-xmatch-positions='{{ (objects_list["all_positions"] if objects_list.get("all_positions") else (objects_list["items"] | xmatch_positions)) | tojson_compact }}'
    hx-on:htmx:load="window.send_xmatch_prefetch && window.send_xmatch_prefetch(this)"
  ></div>

  {#
    Loading overlay — covers the results card with a translucent backdrop and
    a centered spinner+label whenever its `.htmx-request` flag is set (Search
    button, pagination, row-click drill-in). `.htmx-indicator-scoped` only
    reacts when htmx puts the class on the indicator element itself, so
    unrelated requests targeting `#results-slot` don't flash this on. Shows
    on top of the existing rows so the previous results are still visible
    underneath but unmistakably "in transition".
  #}
  <div
    id="results-loading"
    class="htmx-indicator-scoped tw-absolute tw-inset-0 tw-z-10 tw-flex tw-items-center tw-justify-center tw-bg-bg-card/85 tw-rounded tw-pointer-events-none"
    role="status"
    aria-live="polite"
  >
    <div class="tw-flex tw-items-center tw-gap-3 tw-text-accent tw-text-sm tw-font-medium tw-bg-bg-tertiary tw-border tw-border-border tw-rounded tw-px-4 tw-py-2 tw-shadow-lg">
      <svg class="tw-animate-spin" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <circle cx="12" cy="12" r="9" stroke-opacity="0.25"/>
        <path d="M21 12a9 9 0 0 0-9-9" stroke-linecap="round"/>
      </svg>
      <span>Searching…</span>
    </div>
  </div>

  {% if objects_list['items']|length > 0 %}
    <div class="tw-overflow-x-auto">
      <table class="tw-w-full tw-text-sm">
        <thead class="tw-text-left tw-text-text-secondary tw-text-xs tw-uppercase">
          {# Native `title` tooltips (same pattern as the airmass/crossmatch
             panels) explain each column on hover; tw-cursor-help hints they're
             there. #}
          <tr class="tw-border-b tw-border-border">
            <th class="tw-px-3 tw-py-2 tw-cursor-help"
                title="Object identifier (OID) — the ZTF name string or the LSST 64-bit id. Click a row to open the object's detail view.">Object ID</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Number of detections — real alerts above the survey threshold for this object (excludes forced photometry and non-detections).">N det</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="ALeRCE classifier that produced the Class and Prob shown in this row.">Classifier</th>
            <th class="tw-px-3 tw-py-2 tw-cursor-help"
                title="Most probable class for this object from the selected classifier.">Class</th>
            <th class="tw-px-3 tw-py-2 tw-cursor-help"
                title="Probability (0–1) of the most likely class from that classifier.">Prob</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Right ascension — mean position, J2000, in degrees.">RA</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Declination — mean position, J2000, in degrees.">Dec</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Modified Julian Date of the first detection.">First MJD</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Modified Julian Date of the most recent detection.">Last MJD</th>
            {# Two peak magnitudes: difference (transient-relevant) and total /
               apparent (star-relevant). Filled out-of-band by #magstats-loader. #}
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Brightest difference-image magnitude across bands (band shown beside the value) — the relevant peak for transients. ZTF: magmin. LSST: from the peak difference PSF flux.">Peak diff mag</th>
            <th class="tw-px-3 tw-py-2 col-mobile-hide tw-cursor-help"
                title="Brightest total (apparent) magnitude across bands (band shown beside the value) — the relevant peak for stars and variables. ZTF: magmin_corr (blank if the object is uncorrected). LSST: from the mean science flux (no per-band science max is stored).">Peak tot mag</th>
          </tr>
        </thead>
        <tbody>
        {% for obj in objects_list['items'] %}
          <tr
            data-oid="{{ obj.get('oid', '') }}"
            class="tw-border-b tw-border-border/50 hover:tw-bg-bg-tertiary tw-cursor-pointer"
            hx-get="{{ API_URL }}/htmx/detail?oid={{ obj.get('oid', '')|urlencode }}&survey_id={{ survey }}{{ filter_qs|trim }}"
            hx-target="#results-slot"
            hx-swap="innerHTML"
            hx-indicator="#results-loading"
          >
            <td class="tw-px-3 tw-py-2 mono">{{ obj.get('oid', '-') }}</td>
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide">{{ obj.get('n_det', '-') }}</td>
            <td class="tw-px-3 tw-py-2 col-mobile-hide">{{ obj.get('classifier_name', '-') }}</td>
            <td class="tw-px-3 tw-py-2">{{ obj.get('class_name', '-') }}</td>
            <td class="tw-px-3 tw-py-2 mono">
              {% if obj.get('probability') is not none %}{{ "%.3f"|format(obj['probability']) }}{% else %}-{% endif %}
            </td>
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide">
              {% if obj.get('meanra') is not none %}{{ "%.5f"|format(obj['meanra']) }}{% else %}-{% endif %}
            </td>
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide">
              {% if obj.get('meandec') is not none %}{{ "%.5f"|format(obj['meandec']) }}{% else %}-{% endif %}
            </td>
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide">
              {% if obj.get('firstmjd') is not none %}{{ "%.3f"|format(obj['firstmjd']) }}{% else %}-{% endif %}
            </td>
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide">
              {% if obj.get('lastmjd') is not none %}{{ "%.3f"|format(obj['lastmjd']) }}{% else %}-{% endif %}
            </td>
            {# Filled out-of-band by #magstats-loader → /htmx/list_magstats (one bulk TAP query per page). #}
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide"><span id="peakdiff-{{ obj.get('oid', '') }}">…</span></td>
            <td class="tw-px-3 tw-py-2 mono col-mobile-hide"><span id="peaktot-{{ obj.get('oid', '') }}">…</span></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>

    {#
      Lazy fill for the Peak mag / Last mag columns. Fires one bulk TAP query
      for this page's oids once the table has painted; the response is pure
      hx-swap-oob spans that drop into each row's placeholder cells, so
      hx-swap="none" here. Page oids are serialized server-side (same
      items|map(attribute='oid') the data-nav above uses); LSST 64-bit oids are
      already strings via safe_json_loads, so join(',') keeps their precision.
    #}
    {%- set page_oids = objects_list['items'] | map(attribute='oid') | join(',') %}
    <div
      id="magstats-loader"
      class="tw-hidden"
      hx-get="{{ API_URL }}/htmx/list_magstats?survey={{ survey }}&oids={{ page_oids|urlencode }}"
      hx-trigger="load"
      hx-swap="none"
    ></div>

    <div class="tw-flex tw-items-center tw-justify-end tw-gap-3 tw-px-3 tw-py-2 tw-text-sm tw-text-text-secondary tw-border-t tw-border-border">
      {% if objects_list['has_prev'] %}
      <button
        type="button"
        class="tw-px-2 tw-py-1 hover:tw-text-text-primary"
        hx-get="{{ API_URL }}/htmx/list_objects"
        hx-target="#results-slot"
        hx-swap="innerHTML"
        hx-indicator="#results-loading"
        hx-vals='js:{...send_form_Data(), ...send_pagination_data({{ objects_list["prev"] }})}'
      >← Prev</button>
      {% endif %}

      <span class="mono">Page {{ objects_list['current_page'] }}</span>

      {% if objects_list['has_next'] %}
      <button
        type="button"
        class="tw-px-2 tw-py-1 hover:tw-text-text-primary"
        hx-get="{{ API_URL }}/htmx/list_objects"
        hx-target="#results-slot"
        hx-swap="innerHTML"
        hx-indicator="#results-loading"
        hx-vals='js:{...send_form_Data(), ...send_pagination_data({{ objects_list["next"] }})}'
      >Next →</button>
      {% endif %}
    </div>
  {% else %}
    <div class="tw-p-6 tw-text-sm tw-text-text-muted tw-text-center">
      {{ objects_list.get('info_message', 'Results will appear here.') }}
    </div>
  {% endif %}
</div>
