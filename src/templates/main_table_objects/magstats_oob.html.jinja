{#
  Out-of-band fill for the results table's Peak diff mag / Peak tot mag cells.
  One request per page (fired by #magstats-loader on load) returns two
  hx-swap-oob spans per object whose ids match the placeholder spans in
  objects_table.html.jinja (`peakdiff-{oid}` / `peaktot-{oid}`). htmx places
  each by id regardless of the request's target. Missing data → em dash.
#}
{% for oid in oids -%}
  {%- set m = mags.get(oid) -%}
  <span id="peakdiff-{{ oid }}" hx-swap-oob="true">{% if m and m.get('peak_diff_mag') is not none %}{{ "%.2f"|format(m['peak_diff_mag']) }}{% if m.get('peak_diff_band') %} {{ m['peak_diff_band'] }}{% endif %}{% else %}—{% endif %}</span>
  <span id="peaktot-{{ oid }}" hx-swap-oob="true">{% if m and m.get('peak_tot_mag') is not none %}{{ "%.2f"|format(m['peak_tot_mag']) }}{% if m.get('peak_tot_band') %} {{ m['peak_tot_band'] }}{% endif %}{% else %}—{% endif %}</span>
{% endfor %}
