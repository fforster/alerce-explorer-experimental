{#
  Aladin panel — rendered by /htmx/aladin. The server emits the empty target
  div and the RA/Dec; client JS (static/js/aladin.js) probes HiPS coverage
  (PanSTARRS → DESI → SkyMapper → DSS fallback) and boots Aladin Lite on it.

  Aladin Lite v3 is loaded from CDS CDN the first time an aladin panel is
  rendered — it's a megabyte of JS and we don't want it on every page view.
#}
<style>
  /* Aladin Lite's fullscreen is a CSS fixed-overlay (not the native Fullscreen
     API), so page chrome with a positive z-index — notably the panel-help (?)
     tooltips at z-50 — can paint over the fullscreen sky view. While fullscreen
     is active, aladin.js sets `body.aladin-fs-active`; hide those tooltips then
     so nothing bleeds over the sky. (aladin.js also raises the Aladin overlay's
     z-index; this is belt-and-suspenders for the hover cards.) */
  body.aladin-fs-active .panel-help [role="tooltip"] { display: none !important; }
</style>
<div id="aladin-panel" class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-h-full tw-flex tw-flex-col">
  <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
    {% from "_panel_help.html.jinja" import panel_help %}
    {% call panel_help("Sky view", side="right") %}
      <div class="tw-font-semibold tw-mb-1">What's shown</div>
      <p class="tw-mb-3 tw-text-text-secondary">Aladin Lite sky viewer centred on the object, backed by HiPS imagery (PanSTARRS → DESI → SkyMapper → DSS fallback depending on coverage).</p>
      <div class="tw-font-semibold tw-mb-1">Navigation</div>
      <ul class="tw-space-y-0.5 tw-mb-3 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li>Pan: drag</li>
        <li>Zoom: scroll wheel or pinch</li>
        <li>Imagery / overlay picker: toolbar at top-right of the viewer</li>
      </ul>
      <div class="tw-font-semibold tw-mb-1">Stamp footprint</div>
      <p class="tw-text-text-secondary tw-mb-3">An amber polygon traces the on-sky extent of the currently selected science stamp. LSST stamps use the FITS WCS directly; ZTF cutouts ship without WCS so the polygon is reconstructed from a 1″/pix square centred on the object. Updates whenever you pick a different detection in the stamps panel or click another light-curve point.</p>
      <div class="tw-font-semibold tw-mb-1">Crossmatch overlay</div>
      <p class="tw-text-text-secondary tw-mb-3">CDS/NED crossmatches are drawn colour-coded by category —
        <span class="tw-font-semibold" style="color:{{ xmatch_colors['stellar'] }}">stars</span>,
        <span class="tw-font-semibold" style="color:{{ xmatch_colors['agn'] }}">AGN/QSO</span>,
        <span class="tw-font-semibold" style="color:{{ xmatch_colors['host'] }}">galaxies</span> — the
        same schema as the Crossmatch panel. The legend groups them (Stars / AGN/QSO / Galaxies). Click a
        marker to see its details in the info bar at the bottom of the panel (or, in fullscreen, a small popup);
        clicking a galaxy/AGN with a redshift also fills the <em>z</em> input in the light-curve panel.</p>
      <div class="tw-font-semibold tw-mb-1">Contemporaneous LSST objects</div>
      <p class="tw-text-text-secondary">Gray squares mark LSST objects whose mean position lies within 10 arcmin of this object AND whose <em>lastmjd</em> falls within ±2 hr of this object's. Useful for spotting possible trails (asteroids / satellites) that share the same exposure — a near-perfect chain of squares along the same direction is a strong hint. The count is shown on the "LSST neighbours (N)" chip in the legend. Click a square to see its <em>oid</em> and <em>lastmjd</em> in the info bar.</p>
    {% endcall %}
    <div id="aladin-legend-{{ oid }}" class="tw-text-xs tw-text-text-muted tw-font-mono"></div>
  </div>

  {#
    Host fills the remaining vertical space so the panel matches the
    stamps-panel height in this row. Aladin Lite picks up the host's
    runtime size, so dropping the fixed 1:1 aspect doesn't break the
    viewer — it just renders at whatever height the row ends up at.
  #}
  {% if ra is not none and dec is not none %}
    <div
      class="aladin-host tw-relative tw-w-full tw-flex-1 tw-min-h-0 tw-bg-bg-secondary tw-rounded tw-overflow-hidden"
      data-ra="{{ ra }}"
      data-dec="{{ dec }}"
      data-oid="{{ oid }}"
      data-survey="{{ survey_id }}"
      data-legend-id="aladin-legend-{{ oid }}"
      {% if lastmjd is not none %}data-lastmjd="{{ lastmjd }}"{% endif %}
    >
      <div class="aladin-loading tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-text-xs tw-text-text-muted">
        loading sky view…
      </div>
    </div>
    {#
      2-row info bar at the bottom — replaces Aladin's hard-to-close popup.
      Defaults to the object coordinates + a hint; aladin.js fills both rows
      with a clicked marker's details (catalog · id, then its properties).
    #}
    <div id="aladin-info-{{ oid }}" class="tw-mt-2 tw-font-mono tw-text-xs tw-leading-tight tw-min-h-[2.1rem]">
      <div class="aladin-info-row1 tw-text-text-primary tw-truncate">RA {{ "%.5f"|format(ra) }}° · Dec {{ "%.5f"|format(dec) }}°</div>
      <div class="aladin-info-row2 tw-text-text-secondary tw-truncate">Click a marker (star / AGN / galaxy / LSST neighbour) for its details</div>
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">
      No coordinates for this object.
    </div>
  {% endif %}
</div>
